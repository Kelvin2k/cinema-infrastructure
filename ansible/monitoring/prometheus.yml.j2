scrape_configs:
  - job_name: 'node_exporter'
    static_configs:
      - targets: ['{{ project_vps_ip }}:9100']
  - job_name: 'database_exporter'
    static_configs:
      - targets: ['{{ project_vps_ip }}:9104']
  - job_name: 'blackbox_http_probe'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
        - http://{{ project_vps_ip }}:3000  
        - http://{{ project_vps_ip }}:8088 
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: {{ project_vps_ip }}:9115

rule_files:
  - "/etc/prometheus/alert-rules.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets: [alertmanager:9093]        
